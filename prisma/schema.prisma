generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String?
  email     String   @unique
  image     String?
  role      Role     @default(USER)
  banned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments          Comment[]
  likes             Like[]
  bookmarks         Bookmark[]
  categoryFollowers CategoryFollower[]

  @@index([clerkId])
  @@index([email])
}

model Company {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  logo             String?
  description      String   @db.Text
  interviewProcess Json?
  roadmap          Json?
  resources        Json?
  salaryInfo       Json?
  faqs             Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  stories     Story[]
  submissions StorySubmission[]

  @@index([slug])
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  icon        String?
  image       String?

  stories   StoryCategory[]
  followers CategoryFollower[]
  submissions StorySubmission[]

  @@index([slug])
}

model Story {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String   @db.Text
  content        String   @db.Text
  coverImage     String?
  companyId      String?
  authorName     String
  authorImage    String?
  authorRole     String?
  linkedin       String?
  twitter        String?
  instagram      String?
  published      Boolean  @default(false)
  featured       Boolean  @default(false)
  views          Int      @default(0)
  readTime       Int      @default(5)
  outcomeType    String?
  outcomeText    String?
  careerStage    String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company  Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  categories StoryCategory[]
  comments Comment[]
  likes    Like[]
  bookmarks Bookmark[]

  @@index([slug])
  @@index([published, featured])
  @@index([published, createdAt])
  @@index([published, views])
  @@index([companyId])
}

model StoryCategory {
  storyId    String
  categoryId String

  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([storyId, categoryId])
}

model StorySubmission {
  id           String           @id @default(cuid())
  name         String
  email        String
  linkedin     String?
  storyTitle   String
  storyContent String           @db.Text
  resumeUrl    String?
  notes        String?          @db.Text
  status       SubmissionStatus @default(PENDING)
  categoryId   String?
  companyId    String?
  submittedAt  DateTime         @default(now())
  reviewedAt   DateTime?
  reviewNotes  String?

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  company  Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([email])
}

model Comment {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@index([userId])
}

model Like {
  userId    String
  storyId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([userId, storyId])
  @@index([storyId])
}

model Bookmark {
  userId    String
  storyId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([userId, storyId])
  @@index([storyId])
}

model CategoryFollower {
  userId     String
  categoryId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@index([categoryId])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  viewedAt  DateTime @default(now())

  @@index([storyId, viewedAt])
}
